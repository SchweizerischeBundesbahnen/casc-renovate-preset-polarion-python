{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Renovate preset for Polarion Python repositories maintained by the SBB Polarion Team",
  "extends": [
    "github>SchweizerischeBundesbahnen/casc-renovate-preset-polarion"
  ],
  "constraints": {
    "python": ">=3.12"
  },
  "enabledManagers": [
    "pep621",
    "pre-commit",
    "github-actions",
    "custom.regex"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Track python-sbb-polarion pinned by git tag in [tool.uv.sources] (the pep621/uv manager does not bump git-source tags)",
      "managerFilePatterns": [
        "/(^|/)pyproject\\.toml$/"
      ],
      "matchStrings": [
        "python-sbb-polarion\\s*=\\s*\\{[^}]*\\bgit\\s*=\\s*\"https://github\\.com/(?<depName>SchweizerischeBundesbahnen/python-sbb-polarion)\"[^}]*\\btag\\s*=\\s*\"(?<currentValue>v?[0-9][^\"]*)\""
      ],
      "datasourceTemplate": "github-releases"
    }
  ]
}
