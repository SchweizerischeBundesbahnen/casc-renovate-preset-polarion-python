{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Renovate preset for Polarion Python repositories maintained by the SBB Polarion Team",
  "extends": [
    "github>SchweizerischeBundesbahnen/casc-renovate-preset-polarion"
  ],
  "constraints": {
    "python": ">=3.12"
  },
  "enabledManagers": [
    "pep621",
    "pre-commit",
    "github-actions",
    "custom.regex"
  ],
  "packageRules": [
    {
      "description": "Internal SBB packages - Automerge minor/patch immediately",
      "matchPackagePatterns": [
        "^ch\\.sbb\\.",
        "^SchweizerischeBundesbahnen/ch\\.sbb\\.",
        "^python-sbb-polarion$"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "automerge": true,
      "minimumReleaseAge": "0 days"
    },
    {
      "description": "Polarion SUT image - no minimum-release-age wait (internal JFrog registry; its YYMM-N tags bump as major, so this is not scoped to minor/patch)",
      "matchPackageNames": [
        "sbb.jfrog.io/polarion-docker/polarion/polarion"
      ],
      "minimumReleaseAge": "0 days"
    }
  ]
}
