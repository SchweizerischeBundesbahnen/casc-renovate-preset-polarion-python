{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Renovate preset for Polarion Python repositories maintained by the SBB Polarion Team",
  "extends": [
    "github>SchweizerischeBundesbahnen/casc-renovate-preset-polarion"
  ],
  "constraints": {
    "python": ">=3.12"
  },
  "enabledManagers": [
    "pep621",
    "pre-commit",
    "github-actions",
    "custom.regex"
  ],
  "packageRules": [
    {
      "description": "Internal SBB packages - Automerge minor/patch immediately",
      "matchPackagePatterns": [
        "^ch\\.sbb\\.",
        "^SchweizerischeBundesbahnen/ch\\.sbb\\.",
        "^python-sbb-polarion$"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "automerge": true,
      "minimumReleaseAge": "0 days"
    },
    {
      "description": "Internal SBB container images - no minimum-release-age wait (gated by system-tests; not scoped to minor/patch because the Polarion image's YYMM-N tags bump as major)",
      "matchPackageNames": [
        "sbb.jfrog.io/polarion-docker/polarion/polarion",
        "ghcr.io/schweizerischebundesbahnen/*-service"
      ],
      "minimumReleaseAge": "0 days"
    }
  ]
}
